# Copy to /etc/pramen/pramen.env (mode 0640, owned by root:pramen).
# Never commit real credentials. Prefer the instance/role credential chain
# on EC2/ECS; leave AWS_ACCESS_KEY_ID unset in that case.

# Pipeline document installed on the host.
PRAMEN_PIPELINE=/etc/pramen/pipeline.yaml

# PostgreSQL sink DSN (Aurora / RDS). Referenced by the pipeline's
# `${PRAMEN_POSTGRES_DSN}` placeholder when used.
PRAMEN_POSTGRES_DSN=postgres://pramen:CHANGE_ME@aurora-cluster.cluster-xxxx.eu-central-1.rds.amazonaws.com:5432/pramen?sslmode=require

# Inference ledger. Local SQLite by default; use postgres:// for fleets.
PRAMEN_LEDGER_PATH=/var/lib/pramen/ledger/ledger.sqlite
# PRAMEN_LEDGER_PATH=postgres://pramen:CHANGE_ME@aurora-cluster.../pramen?sslmode=require

# OTLP HTTP/protobuf base URL (collector, ADOT, Grafana Alloy, …).
# Final run counters are pushed at run end (see deploy/grafana/).
PRAMEN_OTLP_ENDPOINT=http://127.0.0.1:4318

# AWS default credential chain region (Bedrock + S3). Architecture pins
# the first hosted profile to eu-central-1 without cross-region inference.
AWS_REGION=eu-central-1
AWS_DEFAULT_REGION=eu-central-1

# Optional: only when not using an instance role / IRSA / task role.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Optional: OpenAI-compatible provider key (never for Bedrock).
# PRAMEN_OPENAI_API_KEY=

# Optional: comma-separated OCI hosts allowed for digest-pinned WASM pulls.
# Empty + empty runtime.wasmOciAllowlist = fail closed.
# PRAMEN_WASM_OCI_ALLOWLIST=ghcr.io

# Structured log filter (tracing EnvFilter).
RUST_LOG=info
