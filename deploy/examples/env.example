# Template for local / compose / host env. Copy and fill; never commit secrets.

PRAMEN_POSTGRES_DSN=postgres://pramen:CHANGE_ME@localhost:5432/pramen?sslmode=prefer
PRAMEN_LEDGER_PATH=/var/lib/pramen/ledger/ledger.sqlite
PRAMEN_OTLP_ENDPOINT=http://127.0.0.1:4318
PRAMEN_PIPELINE=deploy/examples/aws-s3-to-aurora.yaml

AWS_REGION=eu-central-1
AWS_DEFAULT_REGION=eu-central-1
# Leave unset on EC2/ECS/EKS when using the instance/task/IRSA role.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Optional OpenAI-compatible provider (not used by the Bedrock example).
# PRAMEN_OPENAI_API_KEY=

# PRAMEN_WASM_OCI_ALLOWLIST=
RUST_LOG=info
